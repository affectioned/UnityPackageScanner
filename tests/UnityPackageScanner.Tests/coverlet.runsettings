<?xml version="1.0" encoding="utf-8" ?>
<RunSettings>
  <DataCollectionRunSettings>
    <DataCollectors>
      <DataCollector friendlyName="XPlat Code Coverage">
        <Configuration>
          <!-- Exclude auto-generated code that we cannot influence -->
          <ExcludeByAttribute>ExcludeFromCodeCoverage,GeneratedCode,DebuggerNonUserCode</ExcludeByAttribute>
          <!-- Exclude the Roslyn-generated regex state machines -->
          <Exclude>[*]System.Text.RegularExpressions.Generated.*</Exclude>
          <!-- TestFixtures is a test-helper assembly, not domain logic -->
          <Exclude>[UnityPackageScanner.TestFixtures]*</Exclude>
          <!-- Program.cs uses top-level statements; no class to decorate -->
          <ExcludeByFile>**/UnityPackageScanner.Cli/Program.cs</ExcludeByFile>
        </Configuration>
      </DataCollector>
    </DataCollectors>
  </DataCollectionRunSettings>
</RunSettings>
