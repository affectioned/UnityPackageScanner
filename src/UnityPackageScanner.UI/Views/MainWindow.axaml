<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:UnityPackageScanner.UI.ViewModels"
        x:Class="UnityPackageScanner.UI.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="Unity Package Scanner"
        Width="1024" Height="700"
        MinWidth="640" MinHeight="480"
        Background="{StaticResource BgBrush}"
        DragDrop.AllowDrop="True">

  <Window.KeyBindings>
    <KeyBinding Gesture="F12" Command="{Binding ToggleConsolePanelCommand}" />
    <KeyBinding Gesture="OemTilde" Command="{Binding ToggleConsolePanelCommand}" />
  </Window.KeyBindings>

  <Grid RowDefinitions="Auto,*,Auto">

    <!-- Header row -->
    <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="12,8">
      <Grid ColumnDefinitions="*,Auto,Auto">

        <!-- File info -->
        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
          <TextBlock Text="Unity Package Scanner" FontWeight="Bold"
                     Foreground="{StaticResource TextBrush}" FontSize="14" />
          <TextBlock Text="|" Foreground="{StaticResource MutedTextBrush}" />
          <TextBlock Text="{Binding PackagePath}" Foreground="{StaticResource MutedTextBrush}"
                     FontSize="12" TextTrimming="CharacterEllipsis" MaxWidth="400" />
          <TextBlock Text="{Binding PackageSize}" Foreground="{StaticResource MutedTextBrush}" FontSize="12" />
        </StackPanel>

        <!-- Verdict badge -->
        <Border Grid.Column="1" Margin="8,0" Padding="12,4" CornerRadius="4">
          <TextBlock Text="{Binding VerdictLabel}" Foreground="{Binding VerdictBrush}"
                     FontWeight="Bold" FontSize="13" />
        </Border>

        <!-- Action buttons -->
        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
          <Button Content="Open…" Click="OnOpenClick" Padding="10,4" />
          <Button Content="F12 Console" Command="{Binding ToggleConsolePanelCommand}"
                  Foreground="{StaticResource MutedTextBrush}" Padding="10,4" />
        </StackPanel>
      </Grid>
    </Border>

    <!-- Status bar when scanning -->
    <ProgressBar Grid.Row="0" IsVisible="{Binding IsScanning}"
                 IsIndeterminate="True" VerticalAlignment="Bottom" Height="2" />

    <!-- Main content split -->
    <Grid Grid.Row="1" ColumnDefinitions="*,4,*">

      <!-- Findings list (left) -->
      <Border Grid.Column="0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
        <Grid RowDefinitions="Auto,*">
          <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                  BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="8,4">
            <TextBlock Text="Findings" Foreground="{StaticResource MutedTextBrush}" FontSize="11" />
          </Border>

          <ScrollViewer Grid.Row="1">
            <ItemsControl ItemsSource="{Binding Findings}" Margin="0">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:FindingViewModel">
                  <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                          Padding="10,8" Background="Transparent"
                          PointerPressed="OnFindingClick">
                    <Grid ColumnDefinitions="Auto,*">
                      <Border Grid.Column="0" Background="{Binding SeverityBrush}"
                              Padding="4,1" CornerRadius="2" VerticalAlignment="Top" Margin="0,2,8,0">
                        <TextBlock Text="{Binding SeverityLabel}" FontSize="9" FontWeight="Bold"
                                   Foreground="White" />
                      </Border>
                      <StackPanel Grid.Column="1" Spacing="2">
                        <TextBlock Text="{Binding Title}" Foreground="{StaticResource TextBrush}"
                                   FontWeight="SemiBold" FontSize="12" />
                        <TextBlock Text="{Binding Pathname}" Foreground="{StaticResource MutedTextBrush}"
                                   FontSize="11" IsVisible="{Binding Pathname, Converter={x:Static ObjectConverters.IsNotNull}}" />
                        <TextBlock Text="{Binding Evidence}" Foreground="{StaticResource MutedTextBrush}"
                                   FontSize="11" TextWrapping="Wrap"
                                   IsVisible="{Binding IsExpanded}" />
                        <TextBlock Text="{Binding Description}" Foreground="{StaticResource TextBrush}"
                                   FontSize="11" TextWrapping="Wrap"
                                   IsVisible="{Binding IsExpanded}" />
                        <TextBlock Text="(advisory — static analysis was unreliable for this DLL)"
                                   Foreground="{StaticResource MutedTextBrush}" FontSize="10"
                                   FontStyle="Italic"
                                   IsVisible="{Binding IsAdvisory}" />
                      </StackPanel>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Grid>
      </Border>

      <!-- Splitter -->
      <GridSplitter Grid.Column="1" ResizeDirection="Columns"
                    Background="{StaticResource BorderBrush}" Width="4" />

      <!-- Package tree (right) -->
      <Grid Grid.Column="2" RowDefinitions="Auto,*">
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="8,4">
          <TextBlock Text="Package Contents" Foreground="{StaticResource MutedTextBrush}" FontSize="11" />
        </Border>

        <ScrollViewer Grid.Row="1">
          <ItemsControl ItemsSource="{Binding PackageEntries}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:PackageEntryViewModel">
                <Grid ColumnDefinitions="Auto,*,Auto" Margin="8,3">
                  <TextBlock Grid.Column="0" Text="{Binding AnalyzabilityMarker}"
                             Foreground="{StaticResource MutedTextBrush}" FontSize="11"
                             Width="16" FontFamily="Consolas,Monospace" />
                  <TextBlock Grid.Column="1" Text="{Binding Pathname}"
                             Foreground="{StaticResource TextBrush}" FontSize="11"
                             TextTrimming="CharacterEllipsis" />
                  <TextBlock Grid.Column="2" Text="{Binding SizeDisplay}"
                             Foreground="{StaticResource MutedTextBrush}" FontSize="10"
                             Margin="8,0,0,0" />
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </Grid>
    </Grid>

    <!-- Console panel (bottom, collapsible) -->
    <Border Grid.Row="2" IsVisible="{Binding IsConsolePanelVisible}"
            Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
            MaxHeight="220">
      <Grid RowDefinitions="Auto,*">
        <!-- Console toolbar -->
        <Border Grid.Row="0" Padding="8,4" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Grid.Column="0" Text="Console" Foreground="{StaticResource MutedTextBrush}" FontSize="11" />
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
              <Button Content="Clear" Click="OnClearLogClick" Padding="6,2" FontSize="11" />
              <Button Content="✕" Command="{Binding ToggleConsolePanelCommand}" Padding="6,2" FontSize="11" />
            </StackPanel>
          </Grid>
        </Border>

        <!-- Log entries -->
        <ScrollViewer Grid.Row="1" x:Name="LogScrollViewer">
          <ItemsControl ItemsSource="{Binding LogEntries}" x:Name="LogItemsControl">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:LogEntryViewModel">
                <Grid ColumnDefinitions="Auto,Auto,*" Margin="4,1">
                  <TextBlock Grid.Column="0" Text="{Binding Timestamp}"
                             Foreground="{StaticResource MutedTextBrush}" FontSize="10"
                             FontFamily="Consolas,Monospace" Margin="0,0,8,0" />
                  <Border Grid.Column="1" Background="{Binding LevelBrush}"
                          Padding="3,0" CornerRadius="2" Margin="0,0,6,0">
                    <TextBlock Text="{Binding LevelLabel}" FontSize="9" Foreground="Black"
                               FontWeight="Bold" FontFamily="Consolas,Monospace" />
                  </Border>
                  <TextBlock Grid.Column="2" Text="{Binding Message}"
                             Foreground="{StaticResource TextBrush}" FontSize="11"
                             TextWrapping="Wrap" />
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </Grid>
    </Border>

    <!-- Drag-drop overlay hint -->
    <Border Grid.Row="1" IsHitTestVisible="False"
            IsVisible="{Binding !PackageEntries.Count}"
            Background="#1A000000">
      <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
        <TextBlock Text="Drop a .unitypackage here" Foreground="{StaticResource MutedTextBrush}"
                   FontSize="16" HorizontalAlignment="Center" />
        <TextBlock Text="or click Open… to browse" Foreground="{StaticResource MutedTextBrush}"
                   FontSize="12" HorizontalAlignment="Center" />
        <TextBlock Text="{Binding ScanStatus}" Foreground="{StaticResource MutedTextBrush}"
                   FontSize="11" HorizontalAlignment="Center"
                   IsVisible="{Binding ScanStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
      </StackPanel>
    </Border>
  </Grid>
</Window>
